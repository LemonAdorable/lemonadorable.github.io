---
import type { CollectionEntry } from 'astro:content'

import { Icon } from 'astro-pure/user'
import { getCategoryLabel, getPostCategorySegments } from '@/utils/content-paths'

interface Props {
  post: CollectionEntry<'blog'>
  inboundLinks: number
  outboundLinks: number
  readingTime?: string
}

const { post, inboundLinks, outboundLinks, readingTime } = Astro.props
const categories = getPostCategorySegments(post)
const published = post.data.publishDate
const updated = post.data.updatedDate

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  }).format(date)
---

<nav class='article-rail' aria-label='文章辅助导航'>
  {/* Header with Circle Progress */}
  <div class='rail-header'>
    <div class='progress-circle-container'>
      <svg class='progress-circle' viewBox='0 0 36 36'>
        <path
          class='circle-bg'
          d='M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831'></path>
        <path
          id='rail-progress-path'
          class='circle-fill'
          stroke-dasharray='0, 100'
          d='M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831'></path>
      </svg>
      <div id='rail-progress-text' class='progress-text'>0%</div>
    </div>
    <div class='header-info'>
      <h2 class='font-medium m-0 flex-shrink-0 text-[1rem] uppercase'>阅读概览</h2>
    </div>
  </div>

  {/* Action Pills */}
  <div class='action-pill-group'>
    <a href='/blog' class='action-pill' title='返回博客首页'>
      <Icon name='document' />
      <span>首页</span>
    </a>
    {
      inboundLinks + outboundLinks > 0 ? (
        <a href='#wikilinks-section' class='action-pill' title='定位到双向链接'>
          <Icon name='link' />
          <span>关联</span>
        </a>
      ) : (
        <span class='action-pill is-disabled' aria-disabled='true'>
          <Icon name='link' />
          <span>暂无关联</span>
        </span>
      )
    }
    <a href='#' onclick='history.back(); return false;' class='action-pill' title='返回上一页'>
      <svg
        xmlns='http://www.w3.org/2000/svg'
        width='24'
        height='24'
        viewBox='0 0 24 24'
        fill='none'
        stroke='currentColor'
        stroke-width='2.5'
        stroke-linecap='round'
        stroke-linejoin='round'
      >
        <path d='m15 18-6-6 6-6'></path>
      </svg>
      <span>返回</span>
    </a>
  </div>

  {/* Minimalist Properties Section */}
  <div class='rail-meta'>
    <div class='meta-item'>
      <span class='meta-label'>预计阅读</span>
      <span class='meta-value'>
        {!readingTime || readingTime === '0 min' ? '1 min' : readingTime}
      </span>
    </div>

    <div class='meta-item'>
      <span class='meta-label'>双向链接</span>
      <span class='meta-value'>
        {inboundLinks + outboundLinks > 0 ? `${inboundLinks + outboundLinks} 条` : '暂无关联'}
      </span>
    </div>
    {
      categories.length > 0 && (
        <div class='meta-item'>
          <span class='meta-label'>文章分类</span>
          <div class='meta-value category-links'>
            {categories.map((category) => (
              <a href={`/categories/${category.path}`} class='hover:text-primary transition-colors'>
                {getCategoryLabel(category.name)}
              </a>
            ))}
          </div>
        </div>
      )
    }

    <div class='meta-item'>
      <span class='meta-label'>发布时间</span>
      <time class='meta-value font-mono opacity-80' datetime={published.toISOString()}>
        {formatDate(published)}
      </time>
    </div>

    {
      updated && (
        <div class='meta-item'>
          <span class='meta-label'>最近更新</span>
          <time class='meta-value font-mono opacity-80' datetime={updated.toISOString()}>
            {formatDate(updated)}
          </time>
        </div>
      )
    }
  </div>
</nav>

<script>
  function updateReadingAnalytics() {
    const progressPath = document.getElementById('rail-progress-path') as SVGPathElement | null
    const progressText = document.getElementById('rail-progress-text')
    const contentEl = document.getElementById('content')

    if (!contentEl) return

    const scrollTop = window.scrollY || document.documentElement.scrollTop
    const contentTop = contentEl.offsetTop
    const contentHeight = contentEl.scrollHeight
    const viewportHeight = window.innerHeight

    const maxScrollable = Math.max(0, contentHeight + contentTop - viewportHeight)
    const progress =
      maxScrollable === 0 ? 0 : Math.max(0, Math.min(100, (scrollTop / maxScrollable) * 100))

    if (progressPath) {
      progressPath.setAttribute('stroke-dasharray', `${progress}, 100`)
    }
    if (progressText) {
      progressText.textContent = `${Math.round(progress)}%`
    }
  }

  window.addEventListener('scroll', updateReadingAnalytics)
  window.addEventListener('resize', updateReadingAnalytics)
  updateReadingAnalytics()
  document.addEventListener('astro:page-load', updateReadingAnalytics)
</script>

<style>
  .article-rail {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    padding: 0.25rem;
  }

  /* Header */
  .rail-header {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .progress-circle-container {
    position: relative;
    width: 2.75rem;
    height: 2.75rem;
    flex-shrink: 0;
  }

  .progress-circle {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }
  .circle-bg {
    fill: none;
    stroke: hsl(var(--muted));
    stroke-width: 3.5;
  }
  .circle-fill {
    fill: none;
    stroke: hsl(var(--primary));
    stroke-width: 3.5;
    stroke-linecap: round;
    transition: stroke-dasharray 0.3s ease;
  }

  .progress-text {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 700;
    font-family: var(--font-mono);
    color: hsl(var(--foreground));
  }

  .header-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* Action Group */
  .action-pill-group {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
  }

  .action-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    padding: 0.6rem 0.25rem;
    background: hsl(var(--muted) / 0.3);
    border: 1px solid hsl(var(--border) / 0.5);
    border-radius: 0.75rem;
    color: hsl(var(--muted-foreground));
    transition: all 0.25s ease;
    text-decoration: none;
  }

  .action-pill:hover {
    background: hsl(var(--primary) / 0.08);
    border-color: hsl(var(--primary) / 0.35);
    color: hsl(var(--primary));
    transform: translateY(-1px);
  }

  .action-pill.is-disabled {
    cursor: default;
    opacity: 0.55;
  }

  .action-pill.is-disabled:hover {
    border-color: hsl(var(--border) / 0.5);
    color: hsl(var(--muted-foreground));
    background: hsl(var(--muted) / 0.3);
    transform: none;
  }

  .action-pill :global(svg) {
    width: 1.25rem;
    height: 1.25rem;
  }

  .action-pill span {
    font-size: 0.75rem;
    font-weight: 500;
  }

  /* Minimalist Metadata */
  .rail-meta {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 0 0.25rem;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .meta-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: hsl(var(--muted-foreground));
  }

  .meta-value {
    font-size: 0.9rem;
    font-weight: 500;
    color: hsl(var(--foreground));
  }

  .category-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .category-links a {
    text-decoration: underline decoration-dotted underline-offset-4 decoration-border;
  }
</style>
