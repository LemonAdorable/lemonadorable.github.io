---
import { Icon } from 'astro-pure/user'

interface ApplyInfo {
  name: string
  val: string
}

const { info, applyUrl, editUrl } = Astro.props as {
  info: ApplyInfo[]
  applyUrl: string
  editUrl: string
}

const allInfo = info.map(({ name, val }) => `${name}: ${val}`).join('\n')
---

<div class='not-prose my-5 rounded-2xl border bg-card p-5 sm:p-6'>
  <div class='flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between'>
    <div>
      <p class='m-0 text-lg font-semibold text-foreground'>想和本站交换友链？</p>
      <p class='mb-0 mt-1 text-sm text-muted-foreground'>
        添加本站后提交申请，机器人会校验回链，再由维护者人工审核内容。
      </p>
    </div>
    <button
      type='button'
      data-open-friend-apply
      class='inline-flex h-10 shrink-0 cursor-pointer items-center justify-center gap-2 rounded-xl border border-foreground bg-foreground px-4 text-sm font-medium text-background transition-opacity hover:opacity-80'
    >
      <Icon name='link' />
      查看申请指南
    </button>
  </div>
</div>

<dialog
  id='friend-apply-dialog'
  class='not-prose m-auto max-h-[94vh] w-[min(94vw,44rem)] overflow-hidden rounded-2xl border bg-background p-0 text-foreground shadow-2xl backdrop:bg-black/55 lg:w-[min(94vw,64rem)]'
>
  <div class='flex max-h-[94vh] flex-col'>
    <header class='flex items-center justify-between border-b px-5 py-4 sm:px-6 lg:py-3'>
      <div>
        <h3 class='m-0 text-lg font-semibold lg:text-base'>友链申请指南</h3>
        <p class='mb-0 mt-1 text-xs text-muted-foreground'>自动技术校验 + 人工内容审核</p>
      </div>
      <button
        type='button'
        data-close-friend-apply
        aria-label='关闭申请指南'
        class='flex h-9 w-9 cursor-pointer items-center justify-center rounded-full border bg-background text-xl leading-none transition-colors hover:bg-muted'
      >
        ×
      </button>
    </header>

    <div class='friend-apply-body grid gap-5 overflow-y-auto px-5 py-5 sm:px-6 lg:grid-cols-2 lg:gap-x-6 lg:gap-y-4 lg:py-4'>
      <section>
        <div class='mb-3 flex items-center justify-between gap-3'>
          <h4 class='m-0 text-base font-semibold'>本站信息</h4>
          <button
            type='button'
            data-copy-value={allInfo}
            class='cursor-pointer rounded-lg border bg-background px-3 py-1.5 text-xs transition-colors hover:bg-muted'
          >
            复制全部
          </button>
        </div>
        <div class='grid gap-2 lg:gap-1.5'>
          {
            info.map(({ name, val }) => (
              <div class='flex items-center gap-3 rounded-xl border bg-muted/35 px-3 py-2.5 lg:py-2'>
                <div class='min-w-0 flex-1'>
                  <div class='text-xs text-muted-foreground'>{name}</div>
                  <div class='mt-0.5 break-all text-sm'>{val}</div>
                </div>
                <button
                  type='button'
                  data-copy-value={val}
                  aria-label={`复制 ${name}`}
                  class='flex h-8 w-8 shrink-0 cursor-pointer items-center justify-center rounded-lg border bg-background transition-colors hover:bg-muted'
                >
                  <Icon name='copy' />
                </button>
              </div>
            ))
          }
        </div>
      </section>

      <section class='mt-6 lg:mt-0'>
        <h4 class='m-0 text-base font-semibold'>申请流程</h4>
        <ol class='mt-3 grid list-none gap-3 p-0 lg:gap-2'>
          <li class='flex gap-3'>
            <span
              class='flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-foreground text-xs font-semibold text-background'
            >
              1
            </span>
            <div>
              <p class='m-0 text-sm font-medium'>先添加本站友链</p>
              <p class='mb-0 mt-1 text-xs leading-5 text-muted-foreground'>
                将上方信息加入你的友链页面，并确保页面可以公开访问。
              </p>
            </div>
          </li>
          <li class='flex gap-3'>
            <span
              class='flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-foreground text-xs font-semibold text-background'
            >
              2
            </span>
            <div>
              <p class='m-0 text-sm font-medium'>填写 GitHub 申请表</p>
              <p class='mb-0 mt-1 text-xs leading-5 text-muted-foreground'>
                提交站点名称、首页、友链页、描述和头像地址。
              </p>
            </div>
          </li>
          <li class='flex gap-3'>
            <span
              class='flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-foreground text-xs font-semibold text-background'
            >
              3
            </span>
            <div>
              <p class='m-0 text-sm font-medium'>自动校验与人工审核</p>
              <p class='mb-0 mt-1 text-xs leading-5 text-muted-foreground'>
                机器人检查可访问性和回链；通过后由维护者审核内容，批准后自动添加。
              </p>
            </div>
          </li>
        </ol>
      </section>

      <section class='mt-6 lg:mt-0'>
        <h4 class='m-0 text-base font-semibold'>申请要求</h4>
        <ul class='mb-0 mt-3 grid gap-2 pl-5 text-sm leading-6 text-muted-foreground lg:gap-1.5 lg:text-xs lg:leading-5'>
          <li>已添加本站友链，且友链页面无需登录即可访问。</li>
          <li>站点使用域名和 HTTP(S)，不接受 IP 地址或私网站点。</li>
          <li>头像地址需能被第三方页面直接作为图片加载；若存在防盗链或访问限制，展示时会使用默认图标兜底。</li>
          <li>至少有一篇原创内容，最近一年内有更新。</li>
          <li>不含色情、暴力、违法、侵权或其他不适合公开推荐的内容。</li>
          <li>长期无法访问、取消回链或内容违规的站点可能被移除。</li>
        </ul>
      </section>

      <section class='mt-6 lg:mt-0'>
        <h4 class='m-0 text-base font-semibold'>头像可访问性检测</h4>
        <p class='mb-0 mt-2 text-xs leading-5 text-muted-foreground'>
          在提交前粘贴头像地址测试一次。检测会模拟浏览器跨站加载图片，结果仅代表当前浏览器网络环境。
        </p>
        <div class='mt-3 grid gap-2 sm:grid-cols-[1fr_auto]'>
          <input
            type='url'
            data-avatar-check-url
            placeholder='https://example.com/avatar.png'
            class='h-10 min-w-0 rounded-xl border bg-background px-3 text-sm outline-none transition-colors focus:border-foreground'
          />
          <button
            type='button'
            data-avatar-check-button
            class='inline-flex h-10 cursor-pointer items-center justify-center rounded-xl border bg-background px-4 text-sm font-medium transition-colors hover:bg-muted disabled:cursor-wait disabled:opacity-60'
          >
            检测头像
          </button>
        </div>
        <p
          data-avatar-check-result
          class='mb-0 mt-2 min-h-5 text-xs leading-5 text-muted-foreground'
          aria-live='polite'
        >
        </p>
      </section>
    </div>

    <footer class='grid gap-2 border-t bg-muted/25 px-5 py-4 sm:grid-cols-2 sm:px-6 lg:py-3'>
      <a
        href={applyUrl}
        target='_blank'
        rel='noopener noreferrer'
        class='inline-flex h-10 items-center justify-center gap-2 rounded-xl bg-foreground px-4 text-sm font-medium text-background no-underline transition-opacity hover:opacity-80'
      >
        <Icon name='github' />
        自助申请友链
      </a>
      <a
        href={editUrl}
        target='_blank'
        rel='noopener noreferrer'
        class='inline-flex h-10 items-center justify-center gap-2 rounded-xl border bg-background px-4 text-sm font-medium text-foreground no-underline transition-colors hover:bg-muted'
      >
        <Icon name='document' />
        提交 PR
      </a>
    </footer>
  </div>
</dialog>

<script>
  function setupFriendApplyGuide() {
    const dialog = document.querySelector<HTMLDialogElement>('#friend-apply-dialog')
    const openButton = document.querySelector<HTMLButtonElement>('[data-open-friend-apply]')
    if (!dialog || !openButton || dialog.dataset.ready === 'true') return

    dialog.dataset.ready = 'true'
    openButton.addEventListener('click', () => dialog.showModal())
    dialog.querySelectorAll<HTMLElement>('[data-close-friend-apply]').forEach((button) => {
      button.addEventListener('click', () => dialog.close())
    })
    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) dialog.close()
    })

    const urlInput = dialog.querySelector<HTMLInputElement>('[data-avatar-check-url]')
    const checkButton = dialog.querySelector<HTMLButtonElement>('[data-avatar-check-button]')
    const checkResult = dialog.querySelector<HTMLElement>('[data-avatar-check-result]')

    const setAvatarCheckResult = (message: string, state: 'idle' | 'success' | 'error' = 'idle') => {
      if (!checkResult) return
      checkResult.textContent = message
      checkResult.dataset.state = state
    }

    const checkAvatarUrl = (url: string) =>
      new Promise<void>((resolve, reject) => {
        const image = new Image()
        const timer = window.setTimeout(() => {
          image.onload = null
          image.onerror = null
          reject(new Error('timeout'))
        }, 8000)

        image.onload = () => {
          window.clearTimeout(timer)
          resolve()
        }
        image.onerror = () => {
          window.clearTimeout(timer)
          reject(new Error('load failed'))
        }
        image.src = url
      })

    checkButton?.addEventListener('click', async () => {
      const rawUrl = urlInput?.value.trim() ?? ''
      if (!rawUrl) {
        setAvatarCheckResult('请先填写头像地址。', 'error')
        return
      }

      let avatarUrl: URL
      try {
        avatarUrl = new URL(rawUrl)
      } catch {
        setAvatarCheckResult('头像地址格式无效，请填写完整的 HTTP(S) URL。', 'error')
        return
      }

      if (!['http:', 'https:'].includes(avatarUrl.protocol)) {
        setAvatarCheckResult('头像地址需要使用 HTTP 或 HTTPS。', 'error')
        return
      }

      setAvatarCheckResult('正在检测头像能否跨站加载...', 'idle')
      checkButton.disabled = true
      try {
        await checkAvatarUrl(avatarUrl.href)
        setAvatarCheckResult('检测通过：这个头像可以在当前浏览器环境中加载。', 'success')
      } catch {
        setAvatarCheckResult(
          '检测失败：头像可能存在防盗链、访问限制，或当前网络无法访问；展示时会使用默认图标兜底。',
          'error'
        )
      } finally {
        checkButton.disabled = false
      }
    })

    dialog.querySelectorAll<HTMLButtonElement>('[data-copy-value]').forEach((button) => {
      button.addEventListener('click', async () => {
        const value = button.dataset.copyValue
        if (!value) return
        await navigator.clipboard.writeText(value)
        document.dispatchEvent(
          new CustomEvent('toast', { detail: { message: 'Copied to clipboard!' } })
        )
      })
    })
  }

  setupFriendApplyGuide()
  document.addEventListener('astro:page-load', setupFriendApplyGuide)
</script>

<style>
  #friend-apply-dialog[open] {
    animation: friend-dialog-in 180ms ease-out;
  }

  @media (min-width: 1024px) and (min-height: 720px) {
    .friend-apply-body {
      overflow-y: visible;
    }
  }

  [data-avatar-check-result][data-state='success'] {
    color: hsl(142 71% 35%);
  }

  [data-avatar-check-result][data-state='error'] {
    color: hsl(0 84% 60%);
  }

  @keyframes friend-dialog-in {
    from {
      opacity: 0;
      transform: translateY(10px) scale(0.98);
    }
  }
</style>
